datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  role          String   @default("user")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model Workspace {
  id         String   @id @default(uuid())
  name       String
  ownerId    String   @unique @map("owner_id")
  inviteCode String   @unique @map("invite_code")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("member")
  joinedAt    DateTime @default(now()) @map("joined_at")

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @map("updated_at")

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

model ChatSession {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  title     String    @default("New Chat")
  summary   String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("chat_sessions")
}

model Message {
  id                Int      @id @default(autoincrement())
  userId            String   @map("user_id")
  sessionId         String?  @map("session_id")
  platform          String
  senderId          String   @map("sender_id")
  senderName        String?  @map("sender_name")
  content           String?
  messageType       String   @default("text") @map("message_type")
  fileId            Int?     @map("file_id")
  platformMessageId String?  @map("platform_message_id")
  isOutgoing        Boolean  @default(false) @map("is_outgoing")
  timestamp         DateTime @default(now())
  ragSources        Json?    @map("rag_sources")
  metadata          Json?    @map("metadata")

  @@index([userId])
  @@index([userId, timestamp])
  @@index([sessionId])
  @@index([platformMessageId])
  @@index([timestamp])
  @@map("messages")
}

model File {
  id            Int      @id @default(autoincrement())
  userId        String   @map("user_id")
  workspaceId   String?  @map("workspace_id")
  originalName  String   @map("original_name")
  storageUrl    String   @map("storage_url")
  fileType      String   @map("file_type")
  folder        String?
  sizeBytes     BigInt   @map("size_bytes")
  uploadedAt    DateTime @default(now()) @map("uploaded_at")
  extractedText String?  @map("extracted_text")
  accessScope   String   @default("all") @map("access_scope")

  @@index([userId])
  @@index([userId, uploadedAt])
  @@index([workspaceId])
  @@map("files")
}

model PlatformConnection {
  id                   Int     @id @default(autoincrement())
  userId               String  @map("user_id")
  platform             String
  credentialsEncrypted String? @map("credentials_encrypted")
  platformUserId       String? @map("platform_user_id")
  isActive             Boolean @default(true) @map("is_active")

  @@index([userId])
  @@index([userId, platform])
  @@map("platform_connections")
}

model AIProvider {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  workspaceId  String?  @map("workspace_id")
  scope        String   @default("personal")
  providerType String   @map("provider_type")
  name         String
  apiBaseUrl   String   @map("api_base_url")
  apiKey       String   @map("api_key")
  modelId      String   @map("model_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, scope])
  @@map("ai_providers")
}

model SystemSetting {
  id       Int     @id @default(autoincrement())
  key      String  @unique
  value    String?
  isActive Boolean @default(true) @map("is_active")

  @@map("system_settings")
}

model Embedding {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  referenceId String   @map("reference_id")
  collection  String
  document    String
  embedding   Unsupported("vector(3072)")?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([referenceId, collection])
  @@index([collection, userId])
  @@map("embeddings")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  senderId  String   @map("sender_id")
  type      String   @default("info")
  title     String
  message   String?
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, readAt])
  @@map("notifications")
}

model AutoReplyLog {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  question  String
  answer    String
  source    String?
  similarity Float   @map("similarity")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("auto_reply_logs")
}
